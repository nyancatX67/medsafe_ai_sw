# MedSafe AI — Environment Variables
# Copy this file to .env and fill in your values

# ── Ollama (Local LLM) ──────────────────────────────────────────────────────
# Ollama runs locally — no API key needed
# Default host (change if running Ollama on a remote machine)
OLLAMA_HOST=http://localhost:11434

# ── Tesseract OCR ───────────────────────────────────────────────────────────
# Path to Tesseract executable (leave blank for auto-detection)
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux example:   /usr/bin/tesseract
# Mac example:     /opt/homebrew/bin/tesseract
TESSERACT_PATH=

# ── Optional: OpenAI fallback (if not using Ollama) ────────────────────────
# OPENAI_API_KEY=sk-...

# ── Streamlit ───────────────────────────────────────────────────────────────
# Set to "true" for production deployment
STREAMLIT_HIDE_MENU=false
